{
  "name": "@workspace/api-client",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "generate:api": "pnpm exec openapi-ts"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.99.0",
    "@tanstack/react-query": "^5.100.1",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.100.1",
    "zod": "^4.4.3"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "axios": "^1.15.2"
  },
  "exports": {
