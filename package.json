{
  "name": "ecomm",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "generate:schema": "python apps/api/manage.py spectacular --file packages/api-client/schema.yml",
    "generate:client": "pnpm --filter api-client run generate:client",
    "generate:api-client": "pnpm generate:schema && pnpm generate:client"
  },
  "devDependencies": {
    "@workspace/prettier-config": "workspace:^",
    "prettier": "3.8.1",
    "turbo": "^2.5.8"
  },
  "dependencies": {
    "prettier-plugin-tailwindcss": "0.0.0-insiders.f7d2598"
  },
  "packageManager": "pnpm@10.33.0"
}
