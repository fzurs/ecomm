{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/api-client": ["../../packages/api-client/src/index.ts"],
      "@workspace/api-client/*": ["../../packages/api-client/src/*"]
    },
    "plugins": [ { "name": "next" } ]
  },
   "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
